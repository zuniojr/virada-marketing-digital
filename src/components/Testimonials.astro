---
// arquivo: src/components/Testimonials.astro
const depoimentos = [
	{ quote: "\"A criatividade e visão estratégica da Virada transformaram completamente nossa marca local. Hoje somos referência na região.\"", author: "Mariana Costa", role: "CEO, Café Cultura" },
	{ quote: "\"Profissionais, inovadores e focados em resultados! O design entregou muito além do que esperávamos, o engajamento dobrou.\"", author: "Roberto Almeida", role: "Diretor, Urban Imóveis" },
	{ quote: "\"Incríveis! A estratégia que eles montaram nos colocou na primeira página do Google em menos de 3 meses. Sem palavras.\"", author: "Camila Santos", role: "Fundadora, TechSolutions" }
];
---

<section class="testimonials-section">
	<div class="container stagger-in">
		<div class="header">
			<span class="asterisk text-primary">*</span>
			<h2>Vozes dos Nossos <span class="text-primary">Clientes.</span></h2>
		</div>
		
		<p class="subtitle">Descubra como ajudamos negócios reais a alcançarem resultados concretos através de estratégias inovadoras e design de alto impacto.</p>

		<div class="grid">
			{depoimentos.map(d => (
				<div class="card">
					<p>{d.quote}</p>
					<div class="author">
						<strong>{d.author}</strong>
						<span>{d.role}</span>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.testimonials-section {
		padding: var(--section-padding) 0;
		background: white;
	}
	.header {
		display: flex;
		align-items: center;
		gap: 24px;
		margin-bottom: 24px;
	}
	.header .asterisk {
		font-family: var(--font-display);
		font-size: clamp(60px, 10vw, 120px);
		line-height: 0.5;
	}
	h2 {
		font-size: clamp(36px, 6vw, 72px);
		letter-spacing: -1px;
	}
	.subtitle {
		max-width: 600px;
		margin-bottom: 60px;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}
	.card {
		border: 1px solid var(--color-border);
		padding: 40px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		transition: 0.3s ease;
	}
	.card:hover { border-color: var(--color-primary); }
	.card p {
		font-size: 18px;
		color: var(--color-text);
		font-style: italic;
		font-weight: 500;
		margin-bottom: 40px;
		line-height: 1.5;
	}
	.author strong { display: block; font-family: var(--font-heading); text-transform: uppercase; letter-spacing: 1px; }
	.author span { font-size: 14px; color: var(--color-primary); font-weight: 700; }

	@media (max-width: 900px) {
		.grid { grid-template-columns: 1fr; }
	}
</style>
