---
// arquivo: src/components/ContactCTA.astro
---
<section class="contact-section" id="contato">
	<div class="container stagger-in">
		
		<!-- CTA Block -->
		<div class="cta-block">
			<div class="cta-asterisk">*</div>
			<h3><span class="text-outline-white">Vamos Trabalhar</span> Juntos!</h3>
			<a href="#" class="btn btn-outline-white">Fale com a Equipe *</a>
		</div>

		<!-- Contact Form Area -->
		<div class="contact-grid">
			<div class="contact-info">
				<div class="badge"><span class="text-primary">*</span> CONECTE-SE CONOSCO</div>
				<h2>Entre em Contato, <span class="text-primary">Vamos Colaborar.</span></h2>
				<p>Traga suas ideias e vamos transformá-las em resultados tangíveis para o seu negócio. Preencha o formulário e retornaremos rápido.</p>

				<div class="info-details">
					<div>
						<strong>Localização</strong>
						<span>Itajaí, Santa Catarina</span>
					</div>
					<div>
						<strong>Contato</strong>
						<span>contato@virada.com.br</span>
					</div>
				</div>
			</div>

			<form class="contact-form">
				<div class="form-row">
					<div class="input-group">
						<label>Seu Nome <span class="text-primary">*</span></label>
						<input type="text" placeholder="Nome" required />
					</div>
					<div class="input-group">
						<label>Empresa <span class="text-primary">*</span></label>
						<input type="text" placeholder="Nome da Empresa" required />
					</div>
				</div>
				<div class="form-row">
					<div class="input-group">
						<label>Seu E-mail <span class="text-primary">*</span></label>
						<input type="email" placeholder="E-mail" required />
					</div>
					<div class="input-group">
						<label>Telefone <span class="text-primary">*</span></label>
						<input type="tel" placeholder="Telefone" required />
					</div>
				</div>
				<div class="input-group">
					<label>Mensagem</label>
					<textarea rows="4" placeholder="Escreva sua mensagem aqui..."></textarea>
				</div>
				<button type="submit" class="btn btn-black w-full">ENVIAR MENSAGEM</button>
			</form>
		</div>
	</div>
</section>

<style>
	.contact-section { padding: var(--section-padding) 0; }
	
	.cta-block {
		background: var(--color-text); /* Black */
		padding: 100px 40px;
		text-align: center;
		border-radius: 4px;
		position: relative;
		overflow: hidden;
		margin-bottom: 100px;
	}
	.cta-asterisk {
		position: absolute;
		left: -40px;
		top: 50%;
		transform: translateY(-50%);
		font-family: var(--font-display);
		font-size: 400px;
		color: var(--color-primary);
		line-height: 0;
		opacity: 0.1;
		pointer-events: none;
	}
	.cta-block h3 {
		color: var(--color-primary);
		font-size: clamp(40px, 6vw, 80px);
		margin-bottom: 32px;
		position: relative;
		z-index: 2;
	}
	.text-outline-white {
		-webkit-text-stroke: 1px white;
		color: transparent;
	}
	.btn-outline-white {
		border: 1px solid white;
		color: white;
		background: transparent;
		position: relative;
		z-index: 2;
	}
	.btn-outline-white:hover { background: white; color: var(--color-text); }

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.5fr;
		gap: 80px;
	}
	.badge { font-family: var(--font-heading); font-size: 14px; margin-bottom: 16px; letter-spacing: 2px; }
	.contact-info h2 { font-size: clamp(36px, 5vw, 64px); letter-spacing: -1px; margin-bottom: 24px; line-height: 1; }
	.info-details { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 40px; border-top: 1px solid var(--color-border); padding-top: 24px; }
	.info-details strong { display: block; font-family: var(--font-heading); text-transform: uppercase; color: var(--color-text); margin-bottom: 8px; }

	.contact-form { display: flex; flex-direction: column; gap: 24px; }
	.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
	.input-group { display: flex; flex-direction: column; gap: 8px; }
	label { font-family: var(--font-heading); font-weight: 600; text-transform: uppercase; font-size: 14px; }
	input, textarea {
		padding: 16px;
		border: 1px solid var(--color-border);
		background: white;
		border-radius: 4px;
		font-family: var(--font-body);
		outline: none;
	}
	input:focus, textarea:focus { border-color: var(--color-primary); }
	.w-full { width: 100%; padding: 20px !important; }

	@media (max-width: 900px) {
		.contact-grid { grid-template-columns: 1fr; }
		.form-row { grid-template-columns: 1fr; }
		.cta-block { padding: 60px 20px; }
	}
</style>
