---
// arquivo: src/components/Portfolio.astro
const projetos = [
	{ nome: "Branding Tech", img: "https://images.unsplash.com/photo-1600132806370-bf17e65e942f?auto=format&fit=crop&q=80&w=600" },
	{ nome: "App Design", img: "https://images.unsplash.com/photo-1618761714954-0b8cd0026356?auto=format&fit=crop&q=80&w=600" },
	{ nome: "Marketing Camp", img: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=600" },
];
---

<section class="portfolio-section" id="portfolio">
	<div class="container stagger-in">
		<div class="header">
			<h2><span class="text-outline">PORT</span>FOLIO <span class="text-primary">*</span></h2>
			<a href="#" class="btn btn-black">Ver todos</a>
		</div>

		<div class="grid">
			{projetos.map(p => (
				<div class="portfolio-item">
					<img src={p.img} alt={p.nome} />
					<div class="overlay">
						<h3>{p.nome}</h3>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.portfolio-section {
		padding: var(--section-padding) 0;
	}
	.header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 48px;
	}
	h2 {
		font-family: var(--font-display);
		font-size: clamp(48px, 8vw, 96px);
		letter-spacing: -1px;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}
	.portfolio-item {
		position: relative;
		overflow: hidden;
		border-radius: 8px;
		aspect-ratio: 3/4;
		cursor: pointer;
	}
	.portfolio-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}
	.overlay {
		position: absolute;
		inset: 0;
		background: rgba(26, 26, 26, 0.4);
		display: flex;
		align-items: flex-end;
		padding: 32px;
		opacity: 0;
		transition: opacity 0.3s ease;
	}
	.portfolio-item:hover img {
		transform: scale(1.05);
	}
	.portfolio-item:hover .overlay {
		opacity: 1;
	}
	.overlay h3 {
		color: white;
		margin: 0;
		transform: translateY(20px);
		transition: transform 0.4s ease;
		font-size: 24px;
	}
	.portfolio-item:hover .overlay h3 {
		transform: translateY(0);
	}

	@media (max-width: 900px) {
		.grid { grid-template-columns: 1fr; }
		.portfolio-item { aspect-ratio: 16/9; }
	}
</style>
