---
// arquivo: src/components/Hero.astro
---
<section class="hero-section">
	<div class="container hero-grid stagger-in">
		<div class="content">
			<div class="badge">
				<span class="asterisk text-primary">*</span> SOMOS A VIRADA MARKETING
			</div>
			<h1>
				<span class="text-outline">CRIANDO</span> HISTÓRIAS, <br />
				CAPTURANDO <span class="text-primary">ATENÇÃO</span>.
			</h1>
			<p>
				Agência especializada em transformar a presença digital do seu negócio. 
				Combinamos estratégia, design e tecnologia para entregar resultados que impactam.
			</p>
			<div class="hero-actions">
				<a href="#contato" class="btn btn-black">Fale com a gente</a>
				<div class="play-btn">
					<div class="circle">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M8 5v14l11-7z"/>
						</svg>
					</div>
					<span>Ver Vídeo</span>
				</div>
			</div>
		</div>
		<div class="visual">
			<!-- Placeholder estiloso simulando a montagem fotográfica laranja -->
			<div class="hero-image-placeholder">
				<img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80&w=800" alt="Equipe de agência criativa trabalhando feliz" />
			</div>
		</div>
	</div>
</section>

<style>
	.hero-section {
		padding: var(--section-padding) 0;
		overflow: hidden;
	}
	.hero-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
	}
	.badge {
		font-family: var(--font-heading);
		font-size: 14px;
		letter-spacing: 2px;
		display: flex;
		align-items: center;
		margin-bottom: 24px;
	}
	.badge .asterisk {
		font-size: 24px;
		line-height: 0;
		margin-right: 8px;
		margin-top: 6px;
	}
	h1 {
		font-family: var(--font-display);
		font-size: clamp(60px, 8vw, 110px);
		line-height: 0.9;
		margin-bottom: 32px;
		letter-spacing: -2px;
	}
	.text-outline {
		-webkit-text-stroke: 2px var(--color-text);
		color: transparent;
	}
	p {
		max-width: 480px;
		margin-bottom: 40px;
		font-size: 18px;
	}
	.hero-actions {
		display: flex;
		align-items: center;
		gap: 32px;
	}
	.play-btn {
		display: flex;
		align-items: center;
		gap: 12px;
		cursor: pointer;
		font-family: var(--font-heading);
		text-transform: uppercase;
		font-weight: 600;
	}
	.circle {
		width: 50px;
		height: 50px;
		border-radius: 50%;
		border: 2px solid var(--color-primary);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-primary);
		transition: 0.3s;
	}
	.play-btn:hover .circle {
		background: var(--color-primary);
		color: white;
	}

	.visual {
		position: relative;
	}
	.hero-image-placeholder {
		width: 100%;
		aspect-ratio: 4/5;
		background: var(--color-primary);
		border-radius: 12px;
		overflow: hidden;
		position: relative;
	}
	.hero-image-placeholder img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.9;
		mix-blend-mode: luminosity; /* Efeito estiloso */
	}

	@media (max-width: 900px) {
		.hero-grid { grid-template-columns: 1fr; }
		.hero-image-placeholder { aspect-ratio: 16/9; }
	}
</style>
