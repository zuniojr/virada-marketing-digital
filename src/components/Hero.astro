---
// arquivo: src/components/Hero.astro
---

<section class="hero">
	<div class="mesh-gradient"></div>
	<div class="noise"></div>
	
	<div class="container hero-content stagger-in visible">
		<div class="badge"><span>✦ Novo · Taskflow</span></div>
		<h1>Seu time. Uma visão. Zero caos.</h1>
		<p class="subtitle">Taskflow centraliza projetos, prazos e comunicação do seu time em um único lugar, para que nada se perca.</p>
		<div class="actions">
			<a href="#pricing" class="btn btn-primary">Começar grátis →</a>
			<a href="#demo" class="btn btn-secondary">Ver demonstração</a>
		</div>
		<div class="social-proof">
			<div class="avatars">
				<div class="avatar" style="background:var(--color-primary)"></div>
				<div class="avatar" style="background:var(--color-secondary)"></div>
				<div class="avatar" style="background:#a855f7"></div>
			</div>
			<span>Mais de 2.400 times já usam</span>
		</div>
	</div>

	<div class="floating-card">
		<div class="card-inner">
			<span class="trend">+127%</span>
			<span class="label">produtividade</span>
		</div>
	</div>
</section>

<style>
	.hero { position: relative; min-height: 100vh; display: flex; align-items: center; padding: 120px 0; overflow: hidden; }
	.mesh-gradient {
		position: absolute; top: 0; left: 0; width: 100%; height: 100%;
		background: radial-gradient(circle at 20% 30%, rgba(124, 58, 237, 0.15) 0%, transparent 40%),
		            radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.15) 0%, transparent 40%);
		filter: blur(80px); z-index: -2; animation: shift 15s ease-in-out infinite alternate;
	}
	@keyframes shift { from { transform: scale(1); } to { transform: scale(1.1) rotate(5deg); } }
	.noise { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.05; z-index: -1; pointer-events: none;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
	}
	.badge { display: inline-block; padding: 8px 16px; border-radius: 100px; border: 1px solid var(--color-primary); background: rgba(124,58,237,0.1); color: var(--color-primary); margin-bottom: 32px; font-weight: 600; font-size: 14px; }
	h1 { font-size: clamp(52px, 10vw, 96px); font-weight: 800; margin-bottom: 24px; letter-spacing: -0.04em; }
	.subtitle { font-size: clamp(16px, 4vw, 20px); max-width: 600px; margin: 0 auto 40px; }
	.actions { display: flex; gap: 16px; justify-content: center; margin-bottom: 60px; }
	.btn { padding: 18px 36px; border-radius: var(--radius-sm); font-weight: 600; text-decoration: none; transition: 0.3s; }
	.btn-primary { background: var(--color-primary); color: white; box-shadow: 0 10px 30px rgba(124,58,237,0.3); }
	.btn-secondary { border: 1px solid var(--color-border); color: white; backdrop-filter: blur(10px); }
	.social-proof { display: flex; flex-direction: column; align-items: center; gap: 12px; }
	.avatars { display: flex; } .avatar { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--color-bg); margin-left: -10px; }
	.floating-card { position: absolute; bottom: 15%; right: 10%; animation: float 6s ease-in-out infinite; }
	.card-inner { background: var(--color-bg-card); backdrop-filter: blur(12px); border: 1px solid var(--color-border); padding: 24px; border-radius: var(--radius); }
	.trend { display: block; font-size: 32px; font-weight: 800; color: var(--color-primary); font-family: var(--font-display); }
	@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
	@media (max-width: 768px) { .floating-card { display: none; } .actions { flex-direction: column; } .hero-content { text-align: center; } }
</style>
