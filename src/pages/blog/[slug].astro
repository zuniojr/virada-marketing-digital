const { post } = Astro.props;
---

<Layout title={`${post.title} | Blog Virada Marketing Digital`} description={post.title}>
	<Header />
	
	<main>
		<article class="post-detail">
			<section class="post-hero">
				<div class="container stagger-in">
					<a href="/blog" class="back-link">← Voltar ao Blog</a>
					<div class="badge mt-24"><span class="asterisk text-primary">*</span> {post.date}</div>
					<h1>{post.title}</h1>
				</div>
			</section>

			<section class="post-content-area">
				<div class="container stagger-in">
					<div class="featured-image">
						<img src={post.image} alt={post.title} />
					</div>
					<div class="content w-800 mx-auto" set:html={post.content}>
					</div>
				</div>
			</section>
		</article>

		<ContactCTA />
	</main>

	<Footer />
</Layout>

<style>
	.post-detail { padding-bottom: 80px; }
	.post-hero { padding: 80px 0 40px; background: #fffcf9; border-bottom: 1px solid var(--color-border); }
	.back-link { text-decoration: none; color: var(--color-text-muted); font-weight: 600; text-transform: uppercase; font-size: 14px; transition: 0.2s; }
	.back-link:hover { color: var(--color-primary); }
	.mt-24 { margin-top: 24px; }
	
	h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 64px); line-height: 1.1; margin-top: 16px; letter-spacing: -1px; }

	.post-content-area { padding: 60px 0; }
	.featured-image { width: 100%; aspect-ratio: 21/9; border-radius: 12px; overflow: hidden; margin-bottom: 60px; border: 1px solid var(--color-border); }
	.featured-image img { width: 100%; height: 100%; object-fit: cover; }
	
	.w-800 { max-width: 800px; }
	.mx-auto { margin-left: auto; margin-right: auto; }
	
	.content { font-size: 18px; line-height: 1.8; color: var(--color-text); }
	.content :global(h2) { font-family: var(--font-heading); font-size: 32px; margin: 40px 0 20px; text-transform: uppercase; }
	.content :global(h3) { font-family: var(--font-heading); font-size: 24px; margin: 30px 0 15px; }
	.content :global(p) { margin-bottom: 24px; }
	.content :global(ul) { margin-bottom: 24px; padding-left: 20px; }
	.content :global(li) { margin-bottom: 12px; }
	.content :global(strong) { color: var(--color-text); }
</style>
